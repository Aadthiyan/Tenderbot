# ═══════════════════════════════════════════════════════════════════════════════
# TenderBot Global — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── TinyFish ───────────────────────────────────────────────────────────────────
# Get from: https://app.tinyfish.ai → API Keys
TINYFISH_API_KEY=tf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Safety: Set to True ONLY when you want the agent to actually click Submit.
# Leave as False (default) to fill + stage forms without final submission.
ENABLE_LIVE_SUBMIT=False

# ── Fireworks.ai ───────────────────────────────────────────────────────────────
# Get from: https://fireworks.ai → API Keys
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Database → Connect
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=tenderbot

# ── Composio (Slack + Email alerts) ───────────────────────────────────────────
# Get from: https://app.composio.dev → API Keys
COMPOSIO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL=#procurement-alerts

# ── ElevenLabs (Voice briefing) ───────────────────────────────────────────────
# Get from: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── AgentOps (Monitoring) ──────────────────────────────────────────────────────
# Get from: https://app.agentops.ai → Settings → API Keys
AGENTOPS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App URLs ───────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── App Config ─────────────────────────────────────────────────────────────────
# Scoring threshold to trigger deep RFP scrape
SCRAPE_SCORE_THRESHOLD=75
# Scoring threshold to trigger Slack alert
ALERT_SCORE_THRESHOLD=80
# Hour (24h, UTC) for daily scrape cron
DAILY_SCRAPE_HOUR=6
# Hour (24h, UTC) for daily alert sweep + voice briefing
ALERT_SWEEP_HOUR=7
# How often (hours) to run amendment checks
AMENDMENT_CHECK_INTERVAL_HOURS=12
# Max pages to scrape per portal (keep low during dev)
MAX_PORTAL_PAGES=2
# Per-portal agent timeout in seconds
AGENT_TIMEOUT_SECONDS=120
